<site xmlns="http://maven.apache.org/SITE/2.0.0"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:schemaLocation="http://maven.apache.org/SITE/2.0.0
      https://maven.apache.org/xsd/site-2.0.0.xsd"
      name="IKE Starter Set">

    <skin>
        <groupId>org.sentrysoftware.maven</groupId>
        <artifactId>sentry-maven-skin</artifactId>
        <version>7.0.00</version>
    </skin>

    <custom>
        <bodyClass>sentry-green</bodyClass>
        <checkImageLinks>false</checkImageLinks>
        <convertImagesToWebp>false</convertImagesToWebp>
        <convertImagesToThumbnails>false</convertImagesToThumbnails>
        <setExplicitImageSize>false</setExplicitImageSize>
        <keywords>starter set, knowledge set, change set, ledger,
                   IKE Network, knowledge engineering, EL++</keywords>
    </custom>

    <bannerLeft name="IKE Starter Set" href="https://ike.network/">
        <image src="images/ike-logo.svg" alt="IKE"/>
    </bannerLeft>

    <bannerRight name="GitHub &lt;i class='fa-brands fa-github'&gt;&lt;/i&gt;"
        href="https://github.com/IKE-Network/ike-starter-set"/>

    <publishDate format="yyyy-MM-dd"/>

    <body>
        <breadcrumbs>
            <item name="IKE" href="https://ike.network/"/>
            <item name="IKE Starter Set" href="index.html"/>
        </breadcrumbs>
        <!-- GitHub link lives in <bannerRight> only, matching the other
             foundation projects (IKE-Network/ike-issues#521). -->
        <menu name="Starter Set">
            <item name="Overview"                       href="index.html"/>
            <!-- The guide is generated by the ike-doc subproject and copied
                 into the rendered site at post-site; it is a self-contained
                 single file (identicons inlined as data URIs), so it is
                 linked rather than woven into the skin's page chrome. -->
            <item name="Guide (HTML)"                   href="ike-guide.html"/>
            <item name="Guide (PDF)"                    href="ike-guide.pdf"/>
            <item name="Built With"                     href="built-with.html"/>
            <item name="Software Bill of Materials"     href="dependencies.html"/>
        </menu>
        <menu name="Modules" ref="modules"/>
        <menu name="Reports" ref="reports"/>
    </body>
</site>
