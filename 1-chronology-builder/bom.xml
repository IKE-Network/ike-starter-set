    <component type="library" bom-ref="pkg:maven/network.ike.foundation/ike-starter-set@1-chronology-builder-SNAPSHOT?type=pom">
      <publisher>IKE Network</publisher>
      <group>network.ike.foundation</group>
      <name>ike-starter-set</name>
      <version>1-chronology-builder-SNAPSHOT</version>
      <description>IkeFoundation starter set: the ledger-form content set for Ike.
        The source is an append-only version ledger (declared stamps, birth-FQN
        identity); building replays the ledger; the released artifact is a change set.
        Generated by ike:starter-set-create; the SOP is the dev-knowledge-set-sop
        topic family in ike-lab-documents.</description>
