<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.1.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.1.0 https://maven.apache.org/xsd/maven-4.1.0.xsd">
    <modelVersion>4.1.0</modelVersion>

    <parent>
        <groupId>network.ike.platform</groupId>
        <artifactId>ike-parent</artifactId>
        <version>135</version>
        <relativePath/>
    </parent>

    <groupId>network.ike.foundation</groupId>
    <artifactId>ike-starter-set</artifactId>
    <version>1-chronology-builder-SNAPSHOT</version>
    <packaging>pom</packaging>

    <name>Ike Starter Set</name>
    <description>
        IkeFoundation starter set: the ledger-form content set for Ike.
        The source is an append-only version ledger (declared stamps, birth-FQN
        identity); building replays the ledger; the released artifact is a change set.
        Generated by ike:starter-set-create; the SOP is the dev-knowledge-set-sop
        topic family in ike-lab-documents.
    </description>
    <url>https://ike.network/ike-starter-set/</url>
    <inceptionYear>2026</inceptionYear>

    <licenses>
        <license>
            <name>Apache License, Version 2.0</name>
            <url>https://www.apache.org/licenses/LICENSE-2.0.txt</url>
            <distribution>repo</distribution>
        </license>
    </licenses>

    <organization>
        <name>IKE Network</name>
        <url>https://ike.network</url>
    </organization>

    <!-- Required: ike-parent's enforcer fails an inheriting project whose effective
         site URL still points at the in-reactor location (ike-issues#380/#383). -->
    <distributionManagement>
        <site>
            <id>ike-site</id>
            <url>https://ike.network/ike-starter-set/</url>
        </site>
    </distributionManagement>

    <properties>
        <!-- INTERIM: the chronology-store authoring tier (ike-issues#822); resolves
             from a local .m2 until the feature branch merges and releases. -->
        <chronology-store.version>1.127.2-chronology-builder-SNAPSHOT</chronology-store.version>
        <ike-knowledge-provider.version>1-chronology-builder-SNAPSHOT</ike-knowledge-provider.version>
    </properties>

    <subprojects>
        <subproject>ike-terms</subproject>
        <subproject>ike-bindings</subproject>
        <subproject>ike-changeset</subproject>
        <subproject>ike-doc</subproject>
        <subproject>ike-kb</subproject>
    </subprojects>

    <build>
        <plugins>
            <!-- The guide is rendered by the ike-doc subproject into its own
                 target/. Copy both renderings into this aggregator's rendered
                 site so the site.xml menu items resolve and ike:site-publish
                 carries them to gh-pages.

                 post-site runs after the site render and before site:stage —
                 and `ike:site-publish` invokes `site site:stage` — so the
                 files are in place by the time staging copies them.

                 Filtering stays off (the plugin default): ike-guide.pdf is
                 binary and ike-guide.html inlines data-URI identicons. -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-resources-plugin</artifactId>
                <executions>
                    <execution>
                        <id>copy-guide-into-site</id>
                        <phase>post-site</phase>
                        <goals>
                            <goal>copy-resources</goal>
                        </goals>
                        <configuration>
                            <outputDirectory>${project.build.directory}/site</outputDirectory>
                            <resources>
                                <resource>
                                    <directory>${project.basedir}/ike-doc/target/generated-docs/html</directory>
                                    <includes>
                                        <include>ike-guide.html</include>
                                    </includes>
                                </resource>
                                <resource>
                                    <directory>${project.basedir}/ike-doc/target/generated-docs/pdf-prince</directory>
                                    <includes>
                                        <include>ike-guide.pdf</include>
                                    </includes>
                                </resource>
                            </resources>
                        </configuration>
                    </execution>
                </executions>
            </plugin>
        </plugins>
    </build>
</project>
